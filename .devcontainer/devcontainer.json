{
	"name": "hm-typst-template",
	"image": "mcr.microsoft.com/devcontainers/rust:2.0.3-1", 	
	"features": {
	    "ghcr.io/michidk/devcontainers-features/typst:1": {}
	},
	"postCreateCommand": "bash .devcontainer/post-create.sh",
	"postAttachCommand": "git config --global --unset http.sslcainfo || true",
	"mounts": [
		"source=${localWorkspaceFolder}/.devcontainer/.config,target=/home/vscode/.config,type=bind"
	],
	"customizations": {
		"vscode": {
			"extensions": [
				"tomoki1207.pdf"
			]
		}
	}
}